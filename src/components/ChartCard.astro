---
// MD3 Chart Card — Elevated, consumo mensual bar chart
---
<div id="chart-section" class="card-elevated animate-fade-up hidden">
    <!-- Card Header -->
    <div class="flex items-center gap-3 px-4 pb-2 pt-4">
        <span class="icon text-xl text-secondary">
            bar_chart
        </span>
        <span class="font-sans text-base font-medium leading-6 text-on-surface">
            Consumo mensual por espacio (kWh)
        </span>
    </div>
    <hr class="border-outline-variant" />
    
    <!-- Bars — rendered by JS -->
    <div id="bars" class="flex flex-col gap-4 p-4" />

</div>