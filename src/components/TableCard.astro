---
// MD3 Table Card — Elevated with desglose por espacio
---
<div id="table-section" class="card-elevated animate-fade-up hidden">
    <!-- Card Header -->
    <div class="flex items-center gap-3 px-4 pb-2 pt-4">
        <span class="icon text-xl text-secondary">table_chart</span>
        <span class="font-sans text-base font-medium leading-6 text-on-surface">
            Desglose por espacio
        </span>
    </div>
    <hr class="border-outline-variant" />
    
    <!-- Table -->
    <div class="table-wrapper">
        <table class="resp-table">
            <thead>
                <tr class="border-b border-outline-variant">
                    <th class="col-espacio">Espacio</th>
                    <th class="col-equipos">Equipos A/C</th>
                    <th class="col-num">kW total</th>
                    <th class="col-num">kWh / día</th>
                    <th class="col-num">kWh / sem</th>
                    <th class="col-num">kWh / mes</th>
                </tr>
            </thead>
            <tbody id="tbody"></tbody>
            <tfoot id="tfoot"></tfoot>
        </table>
    </div>
</div>


<style>
.table-wrapper {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.resp-table {
  width: 100%;
  border-collapse: collapse;
  min-width: 520px;
}

.resp-table th {
  padding: 10px 12px;
  text-align: left;
  font-size: 10px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: .08em;
  color: var(--color-on-surface-variant);
  white-space: nowrap;
}

.resp-table td {
  padding: 10px 12px;
  font-size: 13px;
  color: var(--color-on-surface);
  border-bottom: 1px solid var(--color-outline-variant);
  vertical-align: middle;
}

.resp-table tbody tr:last-child td { border-bottom: none; }

.resp-table tbody tr:hover td {
  background: rgba(108,219,173,.04);
}

.col-espacio { min-width: 130px; }
.col-equipos { min-width: 160px; }
.col-num {
  text-align: right;
  font-variant-numeric: tabular-nums;
  min-width: 80px;
}

.num-cell {
  text-align: right;
  font-variant-numeric: tabular-nums;
  font-size: 13px;
  color: var(--color-on-surface);
  padding: 10px 12px;
  border-bottom: 1px solid var(--color-outline-variant);
}

.chip-cell {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
}

.total-row td {
  border-top: 2px solid var(--color-outline-variant);
  padding: 12px 12px;
  font-size: 13px;
}
</style>
