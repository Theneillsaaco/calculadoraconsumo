---
// Modal CRUD para gestionar espacios y equipos A/C
---

<!-- Botón flotante para abrir el gestor -->
<button id="btn-gestionar" class="btn-outlined hidden" onclick="abrirGestor()">
  <span class="icon" style="font-size:18px">edit_note</span>
  Gestionar equipos
</button>

<!-- Overlay del modal -->
<div id="modal-overlay" class="modal-overlay hidden" onclick="cerrarGestorOverlay(event)">
  <div class="modal-sheet" role="dialog" aria-modal="true" aria-label="Gestionar equipos">

    <!-- Header del modal -->
    <div class="modal-header">
      <div class="flex items-center gap-3">
        <span class="icon text-xl text-secondary">edit_note</span>
        <span class="font-sans text-base font-medium text-on-surface">Gestionar equipos</span>
      </div>
      <button class="icon-btn" onclick="cerrarGestor()" aria-label="Cerrar">
        <span class="icon">close</span>
      </button>
    </div>

    <div class="modal-body">

      <!-- Lista de espacios existentes -->
      <div id="lista-espacios" class="espacios-list"></div>

      <!-- Botón agregar espacio -->
      <button class="btn-tonal w-full mt-3" onclick="agregarEspacio()">
        <span class="icon" style="font-size:18px">add</span>
        Agregar espacio
      </button>

    </div>

    <!-- Footer del modal -->
    <div class="modal-footer">
      <button class="btn-text" onclick="cerrarGestor()">Cancelar</button>
      <button class="btn-filled" onclick="guardarCambios()">
        <span class="icon" style="font-size:18px">save</span>
        Guardar y recalcular
      </button>
    </div>
  </div>
</div>

<style>
/* ── Modal overlay ── */
.modal-overlay {
  position: fixed;
  display: none;
  inset: 0;
  background: rgba(0,0,0,.6);
  backdrop-filter: blur(4px);
  z-index: 50;
  align-items: flex-end;
  justify-content: center;
  padding: 0;
  animation: fade-in .2s ease both;
}

.modal-overlay.active {
  display: flex;
}

@media (min-width: 640px) {
  .modal-overlay {
    align-items: center;
    padding: 24px;
  }
}

@keyframes fade-in {
  from { opacity: 0; }
  to   { opacity: 1; }
}

/* ── Modal sheet ── */
.modal-sheet {
  background: var(--color-surface-mid);
  border-radius: 28px 28px 0 0;
  width: 100%;
  max-width: 680px;
  max-height: 92dvh;
  display: flex;
  flex-direction: column;
  box-shadow: var(--shadow-elev3);
  animation: slide-up .3s cubic-bezier(.4,0,.2,1) both;
  overflow: hidden;
}

@media (min-width: 640px) {
  .modal-sheet {
    border-radius: 28px;
    max-height: 85dvh;
  }
}

@keyframes slide-up {
  from { transform: translateY(40px); opacity: 0; }
  to   { transform: translateY(0);    opacity: 1; }
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 24px 16px;
  border-bottom: 1px solid var(--color-outline-variant);
  flex-shrink: 0;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 16px 16px;
}

@media (min-width: 640px) {
  .modal-body { padding: 16px 24px; }
}

.modal-footer {
  display: flex;
  justify-content: flex-end;
  gap: 8px;
  padding: 12px 16px 16px;
  border-top: 1px solid var(--color-outline-variant);
  flex-shrink: 0;
}

@media (min-width: 640px) {
  .modal-footer { padding: 12px 24px 20px; }
}

/* ── Espacio card en la lista ── */
.espacio-card {
  background: var(--color-surface-high);
  border-radius: 12px;
  padding: 14px 16px;
  margin-bottom: 10px;
  border: 1px solid var(--color-outline-variant);
}

.espacio-card-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 10px;
}

.espacio-name-input {
  flex: 1;
  background: transparent;
  border: none;
  border-bottom: 1px solid var(--color-outline);
  color: var(--color-on-surface);
  font-family: var(--font-body);
  font-size: 14px;
  font-weight: 500;
  padding: 4px 0;
  outline: none;
  transition: border-color .2s;
  min-width: 0;
}

.espacio-name-input:focus {
  border-bottom-color: var(--color-primary);
}

/* ── Equipo row ── */
.equipo-row {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr auto;
  gap: 8px;
  align-items: end;
  margin-bottom: 8px;
}

@media (max-width: 479px) {
  .equipo-row {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
  }
  .equipo-row .delete-equipo-btn {
    grid-column: 2;
    grid-row: 2;
    justify-self: end;
  }
}

/* ── Mini text field inside modal ── */
.mini-tf {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.mini-tf label {
  font-size: 10px;
  color: var(--color-on-surface-variant);
  text-transform: uppercase;
  letter-spacing: .06em;
  font-weight: 500;
}

.mini-tf input, .mini-tf select {
  background: var(--color-surface-highest);
  border: 1px solid var(--color-outline-variant);
  border-radius: 6px;
  color: var(--color-on-surface);
  font-family: var(--font-body);
  font-size: 13px;
  padding: 6px 8px;
  outline: none;
  transition: border-color .2s;
  width: 100%;
  -moz-appearance: textfield;
}

.mini-tf input::-webkit-inner-spin-button { -webkit-appearance: none; }

.mini-tf input:focus, .mini-tf select:focus {
  border-color: var(--color-primary);
}

.mini-tf select option {
  background: var(--color-surface-highest);
}

/* ── Buttons ── */
.btn-outlined {
  position: relative;
  overflow: hidden;
  background: transparent;
  border: 1px solid var(--color-outline);
  border-radius: var(--radius-full);
  color: var(--color-primary);
  font-family: var(--font-body);
  font-size: 14px;
  font-weight: 500;
  height: 40px;
  padding: 0 24px;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  cursor: pointer;
  transition: border-color .2s, box-shadow .2s;
  white-space: nowrap;
}

.btn-outlined:hover {
  border-color: var(--color-primary);
  box-shadow: var(--shadow-elev1);
  background: rgba(108,219,173,.06);
}

.btn-tonal {
  background: var(--color-secondary-container);
  color: var(--color-on-secondary-container);
  border: none;
  border-radius: var(--radius-full);
  font-family: var(--font-body);
  font-size: 13px;
  font-weight: 500;
  height: 36px;
  padding: 0 20px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  cursor: pointer;
  transition: opacity .2s;
}
.btn-tonal:hover { opacity: .85; }

.btn-text {
  background: transparent;
  border: none;
  color: var(--color-primary);
  font-family: var(--font-body);
  font-size: 14px;
  font-weight: 500;
  height: 40px;
  padding: 0 16px;
  border-radius: var(--radius-full);
  cursor: pointer;
  transition: background .15s;
}
.btn-text:hover { background: rgba(108,219,173,.08); }

.icon-btn {
  background: transparent;
  border: none;
  color: var(--color-on-surface-variant);
  width: 40px; height: 40px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  font-family: "Material Symbols Outlined";
  font-size: 20px;
  transition: background .15s;
}
.icon-btn:hover { background: rgba(225,227,224,.08); }

.delete-espacio-btn {
  background: transparent;
  border: none;
  color: var(--color-error);
  font-family: "Material Symbols Outlined";
  font-size: 18px;
  width: 32px; height: 32px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  flex-shrink: 0;
  transition: background .15s;
}
.delete-espacio-btn:hover { background: rgba(255,180,171,.12); }

.delete-equipo-btn {
  background: transparent;
  border: none;
  color: var(--color-on-surface-variant);
  font-family: "Material Symbols Outlined";
  font-size: 16px;
  width: 28px; height: 28px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  align-self: end;
  flex-shrink: 0;
  transition: color .15s, background .15s;
  padding-bottom: 2px;
}
.delete-equipo-btn:hover { color: var(--color-error); background: rgba(255,180,171,.1); }

.add-equipo-btn {
  background: transparent;
  border: 1px dashed var(--color-outline-variant);
  border-radius: 8px;
  color: var(--color-on-surface-variant);
  font-family: var(--font-body);
  font-size: 12px;
  padding: 6px 12px;
  display: inline-flex; align-items: center; gap: 4px;
  cursor: pointer;
  margin-top: 4px;
  transition: border-color .2s, color .2s;
}
.add-equipo-btn:hover { border-color: var(--color-primary); color: var(--color-primary); }
.add-equipo-btn .icon { font-size: 14px; }

.equipos-label {
  font-size: 11px;
  color: var(--color-on-surface-variant);
  margin: 8px 0 6px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: .05em;
}

.divider { border: none; border-top: 1px solid var(--color-outline-variant); margin: 6px 0 10px; }
</style>
