---
// MD3 Settings Card — Outlined Text Fields + Filled Button
---

<div id="controls" class="card-elevated hidden">
    <!-- Card Header -->
    <div class="flex items-center gap-3 px-4 pb-2 pt-4">
        <span class="icon text-xl text-secondary">
            tune
        </span>
        <span class="font-sans text-base font-medium leading-6 text-on-surface">
            Parametros de calculo
        </span>
    </div>
    <hr class="border-outline-variant" />
    
    <!-- Card body -->
    <div class="flex flex-wrap items-end gap-4 px-4 pb-5 pt-3">
        <!-- MD3 Outlined Text Field: Tarifa -->
        <div class="tf-wrap min-w-[160px] flex-1">
            <span class="icon tf-icon">
                payments
            </span>
            <input
              type="number"
              id="inp-tarifa"
              class="tf-input"
              value="0.09"
              step="0.01"
              min="0"
              placeholder=" "
            />
            <label class="tf-label">Tarifa ($/kWh)</label>
        </div>
        
        <!-- MD3 Outlined Text Field: Dias/semana -->
        <div class="tf-wrap min-w-[160px] flex-1">
          <span class="icon tf-icon">calendar_today</span>
          <input
            type="number"
            id="inp-dias"
            class="tf-input"
            value="5"
            min="1"
            max="7"
            placeholder=" "
          />
          <label class="tf-label">Días / semana</label>
        </div>
     
        <!-- MD3 Filled Button -->
        <button id="btn-calc" class="btn-filled" onclick="runCalc()">
          <span class="icon" style="font-size:18px">calculate</span>
          Calcular consumo
        </button>
    </div>
</div>
